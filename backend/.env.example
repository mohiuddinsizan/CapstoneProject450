PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:password@localhost:5432/omnilock
DB_POOL_MAX=10

JWT_SECRET=replace_with_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=10

MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=omnilock
MQTT_PASSWORD=replace_with_mqtt_password

SMS_API_URL=https://example-sms-provider/api
SMS_API_KEY=replace_with_sms_api_key
SMS_SENDER_ID=OmniLock

PAYMENT_PROVIDER=sslcommerz
PAYMENT_STORE_ID=replace_with_store_id
PAYMENT_STORE_PASSWORD=replace_with_store_password
PAYMENT_WEBHOOK_SECRET=replace_with_webhook_secret

DEVICE_SHARED_SECRET=replace_with_device_secret