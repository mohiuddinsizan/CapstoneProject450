{
  "info": {
    "name": "OmniLock Backend API",
    "description": "Postman collection for OmniLock backend routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "deviceSecret", "value": "replace_with_device_secret" },
    { "key": "bookingId", "value": "" },
    { "key": "lockerId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "planId", "value": "22222222-2222-2222-2222-222222222222" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"01700000000\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Discovery",
      "item": [
        {
          "name": "GET /locations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/locations"
          }
        },
        {
          "name": "GET /lockers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/lockers"
          }
        },
        {
          "name": "GET /lockers/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/lockers/{{lockerId}}"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "POST /bookings/quote",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"planId\": \"{{planId}}\",\n  \"startAt\": \"2026-04-05T10:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/bookings/quote"
          }
        },
        {
          "name": "POST /bookings",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"planId\": \"{{planId}}\",\n  \"startAt\": \"2026-04-05T10:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "GET /bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "POST /subscriptions/extend",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"planId\": \"{{planId}}\"\n}"
            },
            "url": "{{baseUrl}}/subscriptions/extend"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "POST /payments/checkout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\"\n}"
            },
            "url": "{{baseUrl}}/payments/checkout"
          }
        },
        {
          "name": "POST /payments/webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-webhook-signature", "value": "replace_with_signature" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"providerRef\": \"provider-ref-1\",\n  \"status\": \"SUCCESS\"\n}"
            },
            "url": "{{baseUrl}}/payments/webhook"
          }
        },
        {
          "name": "GET /payments/history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/payments/history"
          }
        }
      ]
    },
    {
      "name": "OTP and Access",
      "item": [
        {
          "name": "POST /otp/request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{lockerId}}\"\n}" },
            "url": "{{baseUrl}}/otp/request"
          }
        },
        {
          "name": "POST /otp/verify",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"otp\": \"123456\"\n}" },
            "url": "{{baseUrl}}/otp/verify"
          }
        },
        {
          "name": "POST /access/decision",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-device-secret", "value": "{{deviceSecret}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"userId\": \"33333333-3333-3333-3333-333333333333\",\n  \"nonce\": 0\n}"
            },
            "url": "{{baseUrl}}/access/decision"
          }
        }
      ]
    },
    {
      "name": "Device",
      "item": [
        {
          "name": "POST /device/events",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-device-secret", "value": "{{deviceSecret}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"eventType\": \"OPENED\"\n}" },
            "url": "{{baseUrl}}/device/events"
          }
        },
        {
          "name": "POST /device/telemetry",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-device-secret", "value": "{{deviceSecret}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"payload\": {\n    \"battery\": 93,\n    \"temperature\": 31\n  }\n}" },
            "url": "{{baseUrl}}/device/telemetry"
          }
        }
      ]
    },
    {
      "name": "Biometric",
      "item": [
        {
          "name": "POST /biometric/register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"templateHash\": \"template_hash_value_123456\"\n}" },
            "url": "{{baseUrl}}/biometric/register"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET /admin/lockers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/lockers"
          }
        },
        {
          "name": "POST /admin/locations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"CSE Building\",\n  \"building\": \"Main\",\n  \"floor\": \"2\"\n}" },
            "url": "{{baseUrl}}/admin/locations"
          }
        },
        {
          "name": "POST /admin/unlock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{lockerId}}\"\n}" },
            "url": "{{baseUrl}}/admin/unlock"
          }
        }
      ]
    }
  ]
}